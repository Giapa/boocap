{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "out",
    "declaration": true,
    "types": ["node"]
  },
  "include": ["main/**/*.ts", "electron.vite.config.ts"]
}
